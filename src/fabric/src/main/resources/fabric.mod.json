{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "Stable beta Sodium-native OptiFine resource pack compatibility for Fabric. Existing packs work without bridge layers; use EMF/ETF for entity models and animations.",
  "authors": [
    "The Argus Contributors"
  ],
  "license": "PolyForm-Shield-1.0.0",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.argus.fabric.ArgusFabric"
    ],
    "client": [
      "com.argus.fabric.client.ArgusFabricClient"
    ],
    "sodium:config_api_user": [
      "com.argus.client.sodium.ArgusSodiumConfigEntryPoint"
    ]
  },
  "mixins": [
    "argus.mixins.json",
    {
      "config": "argus.client.mixins.json",
      "environment": "client"
    }
  ],
  "accessWidener": "argus.accesswidener",
  "depends": {
    "fabricloader": ">=${loader_version}",
    "java": ">=25",
    "fabric-api": "*",
    "sodium": "*"
  }
}
